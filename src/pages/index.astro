---
import Layout from '../layouts/Layout.astro';
import SearchBox from '../components/SearchBox.astro';
import { getSermons } from '../lib/sermons';

const sermons = await getSermons();
---

<Layout>
  <div class="card">
    <h2>Overview</h2>
    <p>
      A searchable digital edition of <em>Nibbāna – The Mind Stilled</em>, grounded in the Markdown source text.
    </p>
    <p>Current entries: <strong>{sermons.length}</strong></p>
  </div>

  <SearchBox />
</Layout>
