---
import Layout from '../layouts/Layout.astro';
import SearchBox from '../components/SearchBox.astro';
import { getSermons } from '../lib/sermons';

const sermons = await getSermons();
const sermonCount = sermons.filter((item) => item.data.sermon_number).length;
---

<Layout>
  <section class="card">
    <div class="hero-copy">
      <div class="eyebrow">Digital Edition</div>
      <h2>Direct access to the sermons, with references you can verify.</h2>
      <p class="lede">
        Browse the collection, search exact passages, and use the AI layer as a guided reading tool rather than a black box.
      </p>
      <div class="button-row">
        <a class="button" href="/sermons">Browse sermons</a>
        <a class="button secondary" href="/search">Search passages</a>
      </div>
      <div class="stats">
        <div class="stat"><strong>{sermonCount}</strong><br /><span class="muted">Sermons</span></div>
        <div class="stat"><strong>{sermons.length}</strong><br /><span class="muted">Total sections</span></div>
        <div class="stat"><strong>¶ cited</strong><br /><span class="muted">Passage-level references</span></div>
      </div>
    </div>
  </section>

  <SearchBox />
</Layout>
