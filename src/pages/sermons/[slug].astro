---
import Layout from '../../layouts/Layout.astro';
import { getSermons } from '../../lib/sermons';

export async function getStaticPaths() {
  const sermons = await getSermons();
  return sermons.map((sermon, index) => ({
    params: { slug: sermon.slug },
    props: {
      sermon,
      previous: index > 0 ? sermons[index - 1] : null,
      next: index < sermons.length - 1 ? sermons[index + 1] : null,
    },
  }));
}

const { sermon, previous, next } = Astro.props;
---

<Layout title={`${sermon.data.title} | Nibbāna – The Mind Stilled`}>
  <article class="card article-card">
    <p class="muted">{sermon.data.book}</p>
    <h2>{sermon.data.title}</h2>
    {sermon.data.sermon_number && <p class="muted">Sermon {sermon.data.sermon_number}</p>}
    {
      sermon.blocks.map((block, index) => (
        <section id={block.id} class="passage" style="scroll-margin-top: 1rem; margin-bottom: 1rem; display:grid; grid-template-columns: 3rem 1fr; gap: 0.75rem; align-items:start;">
          <a href={`#${block.id}`} class="passage-number" style="text-decoration:none;">¶{index + 1}</a>
          <div set:html={block.html} />
        </section>
      ))
    }
  </article>

  <nav class="card nav-card">
    <div>{previous && <a href={`/sermons/${previous.slug}/`}>← {previous.data.title}</a>}</div>
    <div>{next && <a href={`/sermons/${next.slug}/`}>{next.data.title} →</a>}</div>
  </nav>
  <script is:inline>
    function highlightInElement(element, query) {
      const terms = query.split(/\s+/).filter(Boolean).sort((a, b) => b.length - a.length);
      if (!terms.length) return;

      const walker = document.createTreeWalker(element, NodeFilter.SHOW_TEXT, {
        acceptNode(node) {
          if (!node.nodeValue?.trim()) return NodeFilter.FILTER_REJECT;
          const parentTag = node.parentElement?.tagName;
          if (parentTag === 'SCRIPT' || parentTag === 'STYLE' || parentTag === 'MARK') {
            return NodeFilter.FILTER_REJECT;
          }
          return NodeFilter.FILTER_ACCEPT;
        }
      });

      const textNodes = [];
      let current;
      while ((current = walker.nextNode())) textNodes.push(current);

      for (const node of textNodes) {
        let replaced = false;
        let fragment = document.createDocumentFragment();
        let text = node.nodeValue;
        let remaining = text;

        while (remaining.length) {
          let earliestIndex = -1;
          let matchedTerm = null;

          for (const term of terms) {
            const index = remaining.toLowerCase().indexOf(term.toLowerCase());
            if (index !== -1 && (earliestIndex === -1 || index < earliestIndex)) {
              earliestIndex = index;
              matchedTerm = term;
            }
          }

          if (earliestIndex === -1 || !matchedTerm) {
            fragment.appendChild(document.createTextNode(remaining));
            break;
          }

          if (earliestIndex > 0) {
            fragment.appendChild(document.createTextNode(remaining.slice(0, earliestIndex)));
          }

          const mark = document.createElement('mark');
          mark.textContent = remaining.slice(earliestIndex, earliestIndex + matchedTerm.length);
          fragment.appendChild(mark);
          replaced = true;
          remaining = remaining.slice(earliestIndex + matchedTerm.length);
        }

        if (replaced) {
          node.parentNode.replaceChild(fragment, node);
        }
      }
    }

    window.addEventListener('DOMContentLoaded', () => {
      const query = new URLSearchParams(window.location.search).get('q')?.trim();
      if (!query) return;
      const target = window.location.hash ? document.querySelector(window.location.hash) : null;
      highlightInElement(target || document.querySelector('article'), query);
    });
  </script>
</Layout>
