---
import Layout from '../../layouts/Layout.astro';
import { getSermons } from '../../lib/sermons';

const sermons = await getSermons();
---

<Layout title="Sermons | Nibbāna – The Mind Stilled">
  <section class="card">
    <div class="eyebrow">Contents</div>
    <h2>Browse the collection</h2>
    <p class="lede">Front matter, all 33 sermons, and back matter in reading order.</p>
  </section>

  <section class="sermon-grid">
    {sermons.map((sermon) => (
      <a href={`/sermons/${sermon.slug}/`}>
        <strong>{sermon.data.title}</strong><br />
        <span class="muted">{sermon.data.sermon_number ? `Sermon ${sermon.data.sermon_number}` : 'Book section'}</span>
      </a>
    ))}
  </section>
</Layout>
